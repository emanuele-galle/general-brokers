---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import GenericHero from '@/components/sections/GenericHero.astro';
import CookieConsent from '@/components/islands/CookieConsent.tsx';
import ContactForm from '@/components/islands/ContactForm.tsx';
import { Icon } from 'astro-icon/components';
import { contactInfo } from '@/data/contact';
---

<BaseLayout
  title="Contatti - General Brokers Srl | Broker Assicurativo Milano"
  description="Contatta General Brokers per una consulenza assicurativa gratuita. Telefono, email, PEC e indirizzo del nostro ufficio a Milano in Via Tonale 20."
>
  <div class="flex min-h-screen">
    <Header />
    <div class="flex flex-col flex-1 lg:ml-72">
      <main class="flex-grow">
        <GenericHero
          title="Contattaci"
          subtitle="CONTATTI"
          description="Il nostro team è a tua disposizione per ogni esigenza assicurativa. Compila il modulo o contattaci direttamente."
        />

        <section class="section-padding bg-white">
          <div class="container-custom">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
              <!-- Contact Form -->
              <div>
                <h2 class="section-title mb-2">Inviaci un Messaggio</h2>
                <p class="text-secondary-600 mb-8">Compila il modulo e ti risponderemo entro 24 ore lavorative.</p>
                <ContactForm client:load />
              </div>

              <!-- Contact Info -->
              <div class="space-y-6">
                <h2 class="section-title mb-2">Informazioni di Contatto</h2>
                <p class="text-secondary-600 mb-8">Puoi raggiungerci anche direttamente attraverso i seguenti canali.</p>

                <div class="card flex items-start gap-4">
                  <div class="w-12 h-12 bg-primary-50 rounded-lg flex items-center justify-center shrink-0">
                    <Icon name="lucide:phone" class="w-6 h-6 text-primary-600" />
                  </div>
                  <div>
                    <h3 class="font-bold text-secondary-900 font-heading mb-1">Telefono</h3>
                    <a href={`tel:${contactInfo.phone.tel}`} class="text-primary-600 hover:text-primary-700 font-medium transition-colors">
                      {contactInfo.phone.display}
                    </a>
                  </div>
                </div>

                <div class="card flex items-start gap-4">
                  <div class="w-12 h-12 bg-primary-50 rounded-lg flex items-center justify-center shrink-0">
                    <Icon name="lucide:mail" class="w-6 h-6 text-primary-600" />
                  </div>
                  <div>
                    <h3 class="font-bold text-secondary-900 font-heading mb-1">Email</h3>
                    <a href={`mailto:${contactInfo.email.general}`} class="text-primary-600 hover:text-primary-700 font-medium transition-colors block">
                      {contactInfo.email.general}
                    </a>
                    <p class="mt-1 block">
                      <span class="text-secondary-900 font-medium">Sinistri: </span>
                      <a href={`mailto:${contactInfo.email.claims}`} class="text-primary-600 hover:text-primary-700 font-medium transition-colors">
                        {contactInfo.email.claims}
                      </a>
                    </p>
                  </div>
                </div>

                <div class="card flex items-start gap-4">
                  <div class="w-12 h-12 bg-primary-50 rounded-lg flex items-center justify-center shrink-0">
                    <Icon name="lucide:mail-check" class="w-6 h-6 text-primary-600" />
                  </div>
                  <div>
                    <h3 class="font-bold text-secondary-900 font-heading mb-1">PEC</h3>
                    <a href={`mailto:${contactInfo.email.pec}`} class="text-secondary-600 hover:text-primary-600 transition-colors">
                      {contactInfo.email.pec}
                    </a>
                  </div>
                </div>

                <div class="card flex items-start gap-4">
                  <div class="w-12 h-12 bg-primary-50 rounded-lg flex items-center justify-center shrink-0">
                    <Icon name="lucide:map-pin" class="w-6 h-6 text-primary-600" />
                  </div>
                  <div>
                    <h3 class="font-bold text-secondary-900 font-heading mb-1">Indirizzo</h3>
                    <p class="text-secondary-600">{contactInfo.address.full}</p>
                  </div>
                </div>

                <div class="card flex items-start gap-4">
                  <div class="w-12 h-12 bg-primary-50 rounded-lg flex items-center justify-center shrink-0">
                    <Icon name="lucide:clock" class="w-6 h-6 text-primary-600" />
                  </div>
                  <div>
                    <h3 class="font-bold text-secondary-900 font-heading mb-1">Orari</h3>
                    <p class="text-secondary-600 text-sm">{contactInfo.hours.weekdays}</p>
                  </div>
                </div>

                <div class="card flex items-start gap-4">
                  <div class="w-12 h-12 bg-primary-50 rounded-lg flex items-center justify-center shrink-0">
                    <Icon name="lucide:landmark" class="w-6 h-6 text-primary-600" />
                  </div>
                  <div>
                    <h3 class="font-bold text-secondary-900 font-heading mb-1">Coordinate Bancarie</h3>
                    <p class="text-secondary-600 text-sm">IBAN: {contactInfo.iban}</p>
                    <p class="text-secondary-600 text-sm">Codice SDI: {contactInfo.sdi}</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Map -->
        <section class="bg-secondary-50">
          <div class="container-custom py-12">
            <div class="rounded-xl overflow-hidden shadow-lg">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2797.5!2d9.206!3d45.4773!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4786c6d5e25c3e0f%3A0x0!2sVia+Tonale+20%2C+20125+Milano!5e0!3m2!1sit!2sit!4v1"
                width="100%"
                height="400"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Mappa ufficio General Brokers Milano"
              ></iframe>
            </div>
          </div>
        </section>

        <!-- CTA Consulenza Gratuita -->
        <section class="bg-primary-600 text-white py-16">
          <div class="container-custom max-w-4xl text-center">
            <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">Richiedi Consulenza</h2>
            <p class="text-xl md:text-2xl font-medium text-white/90">
              Il primo anno la gestione assicurativa &egrave; gratuita!
            </p>
            <a href="/relazione-preventiva" class="inline-flex items-center gap-2 bg-white text-primary-700 hover:bg-white/90 px-8 py-3.5 rounded-full font-semibold transition-colors text-sm md:text-base shadow-lg mt-8">
              Richiedi Ora
            </a>
          </div>
        </section>
      </main>
      <Footer />
      <CookieConsent client:idle />
    </div>
  </div>
</BaseLayout>
