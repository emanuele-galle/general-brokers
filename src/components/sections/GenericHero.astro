---
interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  backgroundImage?: string;
  center?: boolean;
}

const defaultImages = [
  '/images/office/office-1.webp',
  '/images/office/office-2.webp',
  '/images/office/office-3.webp',
  '/images/hero/duomo-milano.webp',
  '/images/hero/stazione-centrale-milano.webp',
  '/images/hero/Galleria-Vittorio-Emanuele.webp',
];

const { title, subtitle, description, backgroundImage, center = false } = Astro.props;

function getImageForTitle(t: string): string {
  if (backgroundImage) return backgroundImage;
  let hash = 0;
  for (let i = 0; i < t.length; i++) {
    hash = ((hash << 5) - hash) + t.charCodeAt(i);
    hash |= 0;
  }
  return defaultImages[Math.abs(hash) % defaultImages.length];
}

const bgImage = getImageForTitle(title);
---

<section class="relative text-white min-h-[600px] md:min-h-[700px] overflow-hidden">
  <div class="absolute inset-0">
    <img src={bgImage} alt="" class="w-full h-full object-cover" />
  </div>
  <div class="absolute inset-0 bg-black/60"></div>
  <div class="container-custom relative z-10 flex items-center min-h-[600px] md:min-h-[700px]">
    <div class:list={['max-w-3xl py-20 md:py-24', center && 'mx-auto text-center']}>
      {subtitle && (
        <p class="text-white/90 text-sm font-semibold uppercase tracking-wider mb-4 drop-shadow-[0_1px_3px_rgba(0,0,0,0.4)]">
          {subtitle}
        </p>
      )}
      <h1 class="font-heading font-bold mb-6 text-white text-4xl md:text-5xl lg:text-6xl drop-shadow-[0_2px_8px_rgba(0,0,0,0.5)]">
        {title}
      </h1>
      <div class="w-16 h-[3px] bg-white rounded-full mb-6"></div>
      {description && (
        <p class="text-white text-lg md:text-xl leading-relaxed drop-shadow-[0_1px_4px_rgba(0,0,0,0.5)]">
          {description}
        </p>
      )}
      <slot />
    </div>
  </div>
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent z-[2]"></div>
</section>
