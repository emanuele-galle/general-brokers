---
import { Icon } from 'astro-icon/components';
---

<section class="relative text-white overflow-hidden min-h-[600px] md:min-h-[700px]">
  <div class="absolute inset-0">
    <img src="/images/hero/duomo-milano.webp" alt="General Brokers - Milano" class="w-full h-full object-cover object-center" loading="eager" fetchpriority="high" />
  </div>
  <div class="absolute inset-0 bg-black/60 z-[1]"></div>
  <div class="container-custom relative z-10 h-full">
    <div class="flex flex-col justify-center min-h-[600px] md:min-h-[700px] py-20 md:py-24">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-black/30 backdrop-blur-sm px-4 py-2 rounded-full border border-white/25 mb-8">
          <span class="w-1.5 h-1.5 bg-white rounded-full"></span>
          <span class="text-xs font-medium tracking-wider uppercase text-white">Milano, dal 1977</span>
        </div>
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.1] mb-4 tracking-tight text-white drop-shadow-[0_2px_8px_rgba(0,0,0,0.5)]">
          Broker Assicurativo
        </h1>
        <p class="text-white/90 text-base md:text-lg leading-relaxed mb-6 max-w-xl drop-shadow-[0_1px_4px_rgba(0,0,0,0.5)]">
          "..al fianco di privati e aziende,<br />
          con competenza e indipendenza,<br />
          per offrire sempre la miglior soluzione assicurativa."
        </p>
        <p class="font-serif text-lg md:text-xl italic text-white mb-8 drop-shadow-[0_1px_4px_rgba(0,0,0,0.5)] text-right max-w-xl pr-8">
          l&apos;assicurezza firmata
        </p>
        <p class="text-white/90 text-sm mb-8 font-medium drop-shadow-[0_1px_3px_rgba(0,0,0,0.4)]">
          Tel. 02 6698.4847 &mdash; info@generalbrokers.it
        </p>
        <a href="/contatti" class="group inline-flex items-center justify-center gap-2 bg-white text-primary-700 hover:bg-white/90 px-8 py-3.5 rounded-full font-semibold transition-colors text-sm md:text-base shadow-lg">
          Richiedi Consulenza
          <Icon name="lucide:arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
        </a>
      </div>
    </div>
  </div>
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent z-[2]"></div>
</section>
