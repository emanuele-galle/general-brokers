---
import { Icon } from 'astro-icon/components';
import { contactInfo } from '@/data/contact';

interface Props {
  title?: string;
  description?: string;
  variant?: 'default' | 'consultation' | 'contact';
  theme?: 'dark' | 'white' | 'secondary';
}

const { variant = 'default', theme = 'dark' } = Astro.props;

const variants = {
  default: {
    title: 'Hai Bisogno di Supporto?',
    description: 'Il nostro team è a tua disposizione per ogni esigenza assicurativa',
    primaryText: 'Contattaci',
    primaryHref: '/contatti',
    secondaryText: contactInfo.phone.display,
    secondaryHref: `tel:${contactInfo.phone.tel}`,
  },
  consultation: {
    title: 'Richiedi una Consulenza Gratuita',
    description: 'Parla con un nostro esperto e trova la soluzione assicurativa perfetta per te',
    primaryText: 'Prenota Consulenza',
    primaryHref: '/contatti',
    secondaryText: 'Chiamaci Ora',
    secondaryHref: `tel:${contactInfo.phone.tel}`,
  },
  contact: {
    title: 'Parliamo del Tuo Progetto',
    description: 'Contattaci per una valutazione personalizzata delle tue esigenze assicurative',
    primaryText: 'Invia Email',
    primaryHref: `mailto:${contactInfo.email.general}`,
    secondaryText: contactInfo.phone.display,
    secondaryHref: `tel:${contactInfo.phone.tel}`,
  },
};

const config = variants[variant];
const title = Astro.props.title || config.title;
const description = Astro.props.description || config.description;

const themes: Record<string, string> = {
  dark: 'bg-secondary-700 text-white',
  white: 'bg-white text-secondary-900 border-t border-secondary-200',
  secondary: 'bg-secondary-50 text-secondary-900',
};
---

<section class:list={['section-padding', themes[theme]]}>
  <div class="container-custom max-w-4xl text-center">
    <h2 class:list={['font-heading text-3xl md:text-4xl font-bold mb-6', theme === 'dark' ? 'text-white' : 'text-secondary-900']}>
      {title}
    </h2>
    <p class:list={['text-lg mb-8', theme === 'dark' ? 'text-white/60' : 'text-secondary-600']}>
      {description}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a href={config.primaryHref} class="btn-primary inline-flex items-center gap-2">
        {config.primaryText}
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
      <a
        href={config.secondaryHref}
        class:list={[
          'btn-outline inline-flex items-center gap-2',
          theme === 'dark'
            ? 'border-white/30 text-white hover:bg-white hover:text-secondary-900'
            : 'border-primary-600 text-primary-600 hover:bg-primary-600 hover:text-white',
        ]}
      >
        <Icon name="lucide:phone" class="w-4 h-4" />
        {config.secondaryText}
      </a>
    </div>
  </div>
</section>
